generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// -- Enums --

enum SignalStatus {
  active
  resolved
}

enum RiskLevel {
  active
  at_risk
  needs_attention
}

enum SignalEventType {
  created
  note_added
  worked_today
  risk_increased
  resolved
  reopened
  link_attached
  edited
  source_added
  source_removed
}

// -- Models --

model Signal {
  id            String       @id @default(cuid())
  title         String
  description   String?
  status        SignalStatus @default(active)
  riskLevel     RiskLevel    @default(active)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  lastWorkedAt  DateTime?
  resolvedAt    DateTime?
  focusedOnDate DateTime?

  events  SignalEvent[]
  sources SignalSource[]
  summaryExclusions SummaryExclusion[]

  @@index([status])
  @@index([riskLevel])
  @@index([focusedOnDate])
  @@index([lastWorkedAt])
  @@index([createdAt])
}

model SignalEvent {
  id        String          @id @default(cuid())
  signalId  String
  eventType SignalEventType
  note      String?
  link      String?
  createdAt DateTime        @default(now())

  signal Signal @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@index([signalId])
  @@index([createdAt])
  @@index([signalId, createdAt])
}

model SignalSource {
  id        String   @id @default(cuid())
  signalId  String
  type      String
  label     String
  url       String?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  signal Signal @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@index([signalId])
  @@index([type])
}

model OriginMapping {
  id         String   @id @default(cuid())
  matchValue String   @unique // normalized hostname
  sourceType String   // e.g. "gitlab", "jira", "figma"
  label      String?  // optional display label
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([matchValue])
}

model SummaryExclusion {
  id        String   @id @default(cuid())
  signalId  String
  date      DateTime @db.Date
  createdAt DateTime @default(now())

  signal Signal @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@unique([signalId, date])
  @@index([signalId])
  @@index([date])
}
